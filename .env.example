# ==============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env.test, .env.beta, or .env.prod and fill in values.
#
# Environment files are loaded based on test_env variable:
#   test_env=test  → .env.test
#   test_env=beta  → .env.beta
#   test_env=prod  → .env.prod
#
# SECURITY: Never commit actual .env files with credentials to git!
# ==============================================================================

# ==============================================================================
# BASE CONFIGURATION
# ==============================================================================

# Base URL of the application under test
BASE_URL=https://test.your-app.com

# Production URL (if needed for specific tests)
URL_PROD=https://your-app.com

# ==============================================================================
# TEST USER CREDENTIALS
# ==============================================================================
# Define credentials for each test user role.
# Create separate users for different permission levels.

# Manager/Admin user (full permissions)
MANAGER_USERNAME=manager@example.com
MANAGER_PASSWORD=SecurePassword123!

# Standard user (regular permissions)
USER_STANDARD_USERNAME=user@example.com
USER_STANDARD_PASSWORD=SecurePassword123!

# Limited user (restricted permissions)
USER_LIMITED_USERNAME=limited@example.com
USER_LIMITED_PASSWORD=SecurePassword123!

# ==============================================================================
# ADD MORE USERS AS NEEDED
# ==============================================================================
# USER_FEATURE_X_USERNAME=featurex@example.com
# USER_FEATURE_X_PASSWORD=SecurePassword123!

# ==============================================================================
# EXTERNAL SERVICES (Optional)
# ==============================================================================

# Gmail API credentials (for email verification tests)
GMAIL_USER=your-test-email@gmail.com
GMAIL_APP_PASSWORD=your-app-specific-password

# Third-party API keys
EXTERNAL_API_KEY=your-api-key-here

# ==============================================================================
# CI/CD VARIABLES (set by CI system, not in .env file)
# ==============================================================================
# These are typically set by GitHub Actions or other CI systems:
#   CI=true
#   GITHUB_RUN_URL=https://github.com/org/repo/actions/runs/123456
