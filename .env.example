# Copy this file to `.env.test`, `.env.beta`, or `.env.prod`.
# Load profile with ENV=<profile> (preferred) or test_env=<profile>.
# Example: ENV=test python -m pytest ... --run-integration

# Base URL of the application under test
BASE_URL=https://test.your-app.com

# Optional production URL
URL_PROD=https://your-app.com

# Required for integration tests
MANAGER_USERNAME=manager@example.com
MANAGER_PASSWORD=replace-with-real-password

# Optional additional users
USER_STANDARD_USERNAME=user@example.com
USER_STANDARD_PASSWORD=replace-with-real-password
USER_LIMITED_USERNAME=limited@example.com
USER_LIMITED_PASSWORD=replace-with-real-password

# Optional external services
GMAIL_USER=your-test-email@gmail.com
GMAIL_APP_PASSWORD=your-app-specific-password
EXTERNAL_API_KEY=your-api-key-here
