# TEST Environment Configuration
# Copy this to .env.test and fill in real values

BASE_URL=https://test.example.com

# Manager User (Admin role)
MANAGER_USERNAME=manager@example.com
MANAGER_PASSWORD=your-password-here

# Regular User
USER_STANDARD_USERNAME=user@example.com
USER_STANDARD_PASSWORD=your-password-here

# Viewer User (Read-only role)
USER_LIMITED_USERNAME=viewer@example.com
USER_LIMITED_PASSWORD=your-password-here

# External Services (optional)
SCORM_CLOUD_ID=
SCORM_CLOUD_SECRET=
