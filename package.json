{
  "name": "@your-org/playwright-tests",
  "version": "1.0.0",
  "description": "Playwright Test Automation Framework Template",
  "private": true,
  "scripts": {
    "// ============ DEBUG & DEVELOPMENT ============": "",
    "run:by-id": "cross-env test_env=test npx playwright test -g @1234 --project=chrome",
    "run:by-id-headed": "cross-env test_env=test npx playwright test -g @1234 --project=chrome --headed",
    "run:multiple": "cross-env test_env=test npx playwright test --grep '@1234|@1235|@1236' --project=chrome",
    "run:by-file-name": "cross-env test_env=test npx playwright test example.ui.test.ts --workers=4 --headed",
    "test:ui-mode": "cross-env test_env=test npx playwright test --ui",
    "// ============ UTILITIES ============": "",
    "codegen": "npx playwright codegen https://your-app.com/ --output=tests/ui-tests/generated.test.ts",
    "report:local": "npx playwright show-report",
    "// ============ LINTING & FORMATTING ============": "",
    "format": "npx prettier --write . --ignore-unknown",
    "format:ci": "prettier -c .",
    "format-lint": "npm run format && npm run lint:fix",
    "lint:fix": "npx eslint . --fix",
    "lint:ci": "npx eslint --max-warnings 0 .",
    "// ============ CRITICAL TESTS ============": "",
    "critical:test": "cross-env test_env=test npx playwright test -g @critical --workers=3",
    "critical:beta": "cross-env test_env=beta npx playwright test -g @critical --workers=3",
    "critical:prod": "cross-env test_env=prod npx playwright test -g @critical --workers=3",
    "critical:chrome": "cross-env test_env=test npx playwright test -g @critical --project=chrome --workers=3",
    "critical:api": "cross-env test_env=test npx playwright test -g \"@critical.*@api|@api.*@critical\" --workers=3",
    "// ============ SMOKE TESTS ============": "",
    "smoke:test": "cross-env test_env=test npx playwright test -g @smoke --workers=3",
    "smoke:beta": "cross-env test_env=beta npx playwright test -g @smoke --workers=3",
    "smoke:prod": "cross-env test_env=prod npx playwright test -g @smoke --workers=3",
    "// ============ REGRESSION TESTS ============": "",
    "regression:test": "cross-env test_env=test npx playwright test -g @regression --workers=4",
    "regression:beta": "cross-env test_env=beta npx playwright test -g @regression --workers=4",
    "regression:chrome": "cross-env test_env=test npx playwright test -g @regression --project=chrome --workers=4",
    "regression:firefox": "cross-env test_env=test npx playwright test -g @regression --project=firefox --workers=4",
    "// ============ API TESTS ============": "",
    "api:test": "cross-env test_env=test npx playwright test -g @api --workers=4",
    "api:beta": "cross-env test_env=beta npx playwright test -g @api --workers=4",
    "api:prod": "cross-env test_env=prod npx playwright test -g @api --workers=3",
    "// ============ E2E TESTS ============": "",
    "e2e:test": "cross-env test_env=test npx playwright test -g @e2e --workers=2",
    "e2e:beta": "cross-env test_env=beta npx playwright test -g @e2e --workers=2",
    "// ============ UI TESTS ============": "",
    "ui:test": "cross-env test_env=test npx playwright test -g @ui --workers=4",
    "ui:beta": "cross-env test_env=beta npx playwright test -g @ui --workers=4",
    "// ============ BY PROJECT ============": "",
    "test:chrome": "cross-env test_env=test npx playwright test --project=chrome --workers=4",
    "test:firefox": "cross-env test_env=test npx playwright test --project=firefox --workers=4",
    "test:safari": "cross-env test_env=test npx playwright test --project=safari --workers=4",
    "// ============ RETRY FAILED ============": "",
    "last-failed:test": "cross-env test_env=test npx playwright test --last-failed --workers=2",
    "last-failed:beta": "cross-env test_env=beta npx playwright test --last-failed --workers=2"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "keywords": [
    "playwright",
    "testing",
    "automation",
    "e2e",
    "api-testing"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.7.0",
    "prettier": "3.9.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "overrides": {
    "uuid": "^14.0.1"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "googleapis": "^173.0.0",
    "lint-staged": "^17.0.8"
  }
}
